@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Sửa bài viết";
}
@model CMS.Data.Entities.Post

<style>
    input[type="file"].form-control {
        color: var(--text-main) !important;
        background-color: var(--input-bg) !important;
        border-color: var(--slate-border) !important;
    }
    input[type="file"].form-control::file-selector-button {
        background-color: var(--slate-border);
        color: var(--text-main);
        border: none;
        border-right: 1px solid var(--slate-border);
        padding: 0.375rem 0.75rem;
        margin-right: 0.75rem;
        border-radius: 6px 0 0 6px;
        cursor: pointer;
        transition: background-color 0.15s;
    }
    input[type="file"].form-control::file-selector-button:hover {
        background-color: #f59e0b;
        color: #000;
    }
    .post-img-preview {
        width: 100%;
        max-height: 200px;
        object-fit: cover;
        border-radius: 10px;
        border: 1px solid var(--slate-border);
        display: block;
    }
    .post-img-empty {
        width: 100%;
        height: 120px;
        background: var(--table-head-bg);
        border: 1px dashed var(--slate-border);
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--text-muted);
        font-size: 0.85rem;
    }
</style>

<div class="mb-4">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary d-inline-flex align-items-center gap-1 mb-2" style="font-size:0.8rem;padding:4px 12px;">
        <i class="bi bi-arrow-left"></i> Quay lại danh sách
    </a>
    <h4 class="fw-bold mb-1">Cập nhật bài viết</h4>
    <p class="text-muted small mb-0">Chỉnh sửa thông tin và nội dung chi tiết bài viết tin tức</p>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-4">
        <form asp-action="Edit" method="post" enctype="multipart/form-data">
            <input type="hidden" asp-for="Id" />

            <div class="mb-3">
                <label class="form-label fw-bold text-secondary" style="font-size: 0.85rem;">Tiêu đề bài viết:</label>
                <input asp-for="Title" class="form-control" placeholder="Nhập tiêu đề bài viết..." required />
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold text-secondary" style="font-size: 0.85rem;">Chuyên mục tin tức:</label>
                <select asp-for="CategoryId" asp-items="ViewBag.CategoryList" class="form-select" required>
                    <option value="">-- Chọn chuyên mục bài viết --</option>
                </select>
            </div>

            <div class="row mb-4 g-3">
                <div class="col-md-4">
                    <label class="form-label">Ảnh đại diện hiện tại:</label>
                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <img src="@Model.ImageUrl" class="post-img-preview"
                             onerror="this.onerror=null;this.style.display='none';this.nextElementSibling.style.display='flex';" />
                        <div class="post-img-empty" style="display:none;">
                            <span><i class="bi bi-image me-1"></i>Không tải được ảnh</span>
                        </div>
                    }
                    else
                    {
                        <div class="post-img-empty">
                            <span><i class="bi bi-image me-1"></i>Chưa có ảnh</span>
                        </div>
                    }
                </div>
                <div class="col-md-8 d-flex flex-column justify-content-center">
                    <label class="form-label">Thay đổi ảnh đại diện mới (bỏ trống nếu giữ ảnh cũ):</label>
                    <input type="file" name="uploadImage" class="form-control" accept="image/*" />
                    <small class="text-muted mt-1"><i class="bi bi-info-circle me-1"></i>Hỗ trợ các định dạng JPG, PNG, WEBP.</small>
                </div>
            </div>

            <div class="mb-4">
                <label class="form-label fw-bold text-secondary" style="font-size: 0.85rem;">Nội dung bài viết:</label>
                <div class="ck-editor-container">
                    <textarea asp-for="Content" class="form-control" rows="12" id="ContentEditor" placeholder="Viết nội dung bài viết ở đây..."></textarea>
                </div>
            </div>

            <hr class="my-4" style="border-color: var(--slate-border);" />

            <div class="d-flex justify-content-end gap-2">
                <a asp-action="Index" class="btn btn-outline-secondary py-2 px-3">Hủy bỏ</a>
                <button type="submit" class="btn btn-primary py-2 px-4 d-inline-flex align-items-center gap-1">
                    <i class="bi bi-check-lg"></i> Cập nhật bài viết
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.ckeditor.com/ckeditor5/41.4.2/classic/ckeditor.js"></script>
    <script>
        ClassicEditor.create(document.querySelector('#ContentEditor'))
            .catch(error => {
                console.error(error);
            });
    </script>
}
