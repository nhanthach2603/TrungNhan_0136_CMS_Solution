@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Quản lý bài viết";
}
@model IEnumerable<CMS.Data.Entities.Post>

<div class="page-title-block d-flex justify-content-between align-items-center">
    <div>
        <h4>Quản lý bài viết tin tức</h4>
        <p>Quản trị nội dung tin tức, bài viết đánh giá máy ảnh, công nghệ trên website</p>
    </div>
    <a asp-action="Create" class="btn btn-primary d-flex align-items-center gap-2">
        <i class="bi bi-plus-lg"></i> Thêm bài viết mới
    </a>
</div>

@if (!Model.Any())
{
    <div class="card">
        <div class="card-body text-center py-5 text-muted">
            <i class="bi bi-file-earmark-text d-block mb-2" style="font-size: 2.5rem; opacity: 0.35;"></i>
            Chưa có bài viết nào được tạo.
        </div>
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var item in Model)
        {
            <div class="col-sm-6 col-xl-4">
                <div class="card h-100 overflow-hidden">
                    <div style="height:180px; background:var(--table-head-bg); overflow:hidden;">
                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                        {
                            <img src="@item.ImageUrl" class="w-100 h-100" style="object-fit:cover;"
                                 onerror="this.onerror=null;this.style.display='none';this.parentElement.querySelector('.no-img').style.display='flex';"
                                 alt="Thumbnail" />
                            <div class="no-img w-100 h-100 align-items-center justify-content-center text-muted" style="display:none;">
                                <i class="bi bi-image" style="font-size:2.5rem; opacity:0.4;"></i>
                            </div>
                        }
                        else
                        {
                            <div class="w-100 h-100 d-flex align-items-center justify-content-center text-muted">
                                <i class="bi bi-image" style="font-size:2.5rem; opacity:0.4;"></i>
                            </div>
                        }
                    </div>
                    <div class="card-body d-flex flex-column p-4">
                        <div class="mb-2">
                            <span class="badge bg-light text-dark border px-2 fw-semibold" style="font-size:0.7rem;">
                                @(item.Category?.Name ?? "Chưa phân loại")
                            </span>
                        </div>
                        <h5 class="fw-bold mb-2" style="font-size:1rem; line-height:1.4; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden; min-height:2.8rem;" title="@item.Title">
                            @item.Title
                        </h5>
                        <p class="text-muted small mb-3" style="display:-webkit-box; -webkit-line-clamp:3; -webkit-box-orient:vertical; overflow:hidden; min-height:3.5rem; line-height:1.6;">
                            @Html.Raw(System.Text.RegularExpressions.Regex.Replace(item.Content ?? "", "<.*?>", string.Empty))
                        </p>
                        <div class="mt-auto pt-3 border-top d-flex justify-content-between align-items-center">
                            <span class="text-muted" style="font-size:0.75rem;">
                                <i class="bi bi-calendar3 me-1"></i>@item.CreatedDate.ToString("dd/MM/yyyy")
                            </span>
                            <div class="action-buttons">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger"
                                   onclick="return confirm('Bạn có chắc chắn muốn xóa bài viết này?')">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

@await Html.PartialAsync("_Pagination")
