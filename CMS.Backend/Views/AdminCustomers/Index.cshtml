@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Quản lý khách hàng";
}
@model IEnumerable<CMS.Data.Entities.Customer>

<div class="page-title-block">
    <h4>Quản lý khách hàng</h4>
    <p>Xem hồ sơ, thông tin liên lạc và lịch sử đơn hàng của các khách hàng đăng ký</p>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th class="ps-4" style="width:80px;">ID</th>
                        <th>HỌ VÀ TÊN</th>
                        <th>EMAIL LIÊN HỆ</th>
                        <th style="width:130px;">SỐ ĐIỆN THOẠI</th>
                        <th>ĐỊA CHỈ ĐĂNG KÝ</th>
                        <th class="text-center" style="width:140px;">ĐƠN HÀNG</th>
                        <th class="pe-4" style="width:140px;">THAO TÁC</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted py-5">
                                <i class="bi bi-people d-block mb-2" style="font-size: 2rem; opacity: 0.35;"></i>
                                Chưa có khách hàng nào đăng ký tài khoản.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 text-secondary fw-bold">#@item.Id</td>
                                <td>
                                    <span class="fw-semibold">@item.FullName</span>
                                </td>
                                <td>
                                    <a href="mailto:@item.Email" class="text-decoration-none">@item.Email</a>
                                </td>
                                <td>
                                    <span>@(string.IsNullOrEmpty(item.Phone) ? "—" : item.Phone)</span>
                                </td>
                                <td>
                                    <div class="text-truncate text-muted" style="max-width:220px;" title="@item.Address">
                                        @(string.IsNullOrEmpty(item.Address) ? "—" : item.Address)
                                    </div>
                                </td>
                                <td class="text-center">
                                    <span class="badge bg-primary-subtle text-primary border border-primary px-3 py-1 fw-bold" style="font-size:0.72rem;">
                                        @(item.Orders?.Count ?? 0) đơn
                                    </span>
                                </td>
                                <td class="pe-4">
                                    <div class="action-buttons">
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info">
                                            <i class="bi bi-clock-history"></i> Lịch sử
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@await Html.PartialAsync("_Pagination")
