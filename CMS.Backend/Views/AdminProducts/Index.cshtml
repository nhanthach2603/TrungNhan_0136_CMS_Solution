@{
    Layout = "_LayoutAdmin";
}
@model IEnumerable<CMS.Data.Entities.Product>

<h2 class="text-primary"><i class="bi bi-box"></i> QUẢN LÝ SẢN PHẨM</h2>
<hr />
<a asp-action="Create" class="btn btn-success mb-3">
    <i class="bi bi-plus-circle"></i> Thêm sản phẩm mới
</a>

<table class="table table-bordered table-hover align-middle">
    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>Hình</th>
            <th>Tên sản phẩm</th>
            <th>Danh mục</th>
            <th>Giá</th>
            <th>Tồn kho</th>
            <th style="width:160px">Thao tác</th>
        </tr>
    </thead>
    <tbody>
        @if (!Model.Any())
        {
            <tr><td colspan="7" class="text-center text-muted">Chưa có sản phẩm nào.</td></tr>
        }
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>
                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                    {
                        <img src="@item.ImageUrl" style="width:50px;height:50px;object-fit:cover" />
                    }
                </td>
                <td><strong>@item.Name</strong></td>
                <td><span class="badge bg-secondary">@item.CategoryProduct?.Name</span></td>
                <td class="text-danger fw-bold">@item.Price.ToString("N0") đ</td>
                <td>@item.StockQuantity</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning">Sửa</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger"
                       onclick="return confirm('Xóa sản phẩm này?')">Xóa</a>
                </td>
            </tr>
        }
    </tbody>
</table>
