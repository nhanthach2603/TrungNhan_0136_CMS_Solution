@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Sửa sản phẩm";
    var imageList = (Model.ImageUrl ?? "").Split(',', StringSplitOptions.RemoveEmptyEntries).ToList();
    var primaryImage = imageList.FirstOrDefault() ?? "";
}
@model CMS.Data.Entities.Product

<style>
    /* ---- Upload zone ---- */
    .upload-zone {
        border: 2px dashed var(--slate-border);
        border-radius: 10px;
        padding: 24px 16px;
        text-align: center;
        cursor: pointer;
        transition: all 0.2s ease;
        background: var(--table-head-bg);
        color: var(--text-muted);
    }
    .upload-zone:hover, .upload-zone.drag-over {
        border-color: #f59e0b;
        background: rgba(245, 158, 11, 0.06);
        color: var(--text-main);
    }
    .upload-zone i { font-size: 2rem; display: block; margin-bottom: 8px; }
    #uploadImages { display: none; }

    /* ---- Image gallery ---- */
    .img-gallery {
        display: grid;
        grid-template-columns: 1fr;
        gap: 12px;
    }
    .img-gallery-item {
        position: relative;
        border-radius: 10px;
        overflow: hidden;
        border: 1px solid var(--slate-border);
        background: var(--table-head-bg);
        aspect-ratio: 16/9;
    }
    .img-gallery-item img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        transition: transform 0.2s;
    }
    .img-gallery-item:hover img { transform: scale(1.03); }
    .img-gallery-item .primary-badge {
        position: absolute;
        top: 8px; left: 8px;
        background: #f59e0b;
        color: #000;
        font-size: 0.65rem;
        font-weight: 700;
        padding: 2px 8px;
        border-radius: 20px;
        letter-spacing: 0.3px;
    }
    .img-gallery-item .remove-btn {
        position: absolute;
        top: 8px; right: 8px;
        width: 28px; height: 28px;
        background: rgba(239, 68, 68, 0.9);
        color: #fff;
        border: none;
        border-radius: 50%;
        font-size: 0.75rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        transition: opacity 0.2s;
        backdrop-filter: blur(4px);
    }
    .img-gallery-item:hover .remove-btn { opacity: 1; }

    /* Thumbnail strip for multiple images */
    .img-thumbnails {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        margin-top: 12px;
    }
    .img-thumb-item {
        position: relative;
        width: 72px;
        height: 72px;
        border-radius: 8px;
        overflow: hidden;
        border: 2px solid var(--slate-border);
        cursor: pointer;
        transition: border-color 0.15s;
        flex-shrink: 0;
    }
    .img-thumb-item.active { border-color: #f59e0b; }
    .img-thumb-item img { width: 100%; height: 100%; object-fit: cover; }
    .img-thumb-item .rm {
        position: absolute;
        top: 2px; right: 2px;
        width: 20px; height: 20px;
        background: rgba(239,68,68,0.9);
        color: #fff;
        border: none;
        border-radius: 50%;
        font-size: 0.65rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        transition: opacity 0.15s;
    }
    .img-thumb-item:hover .rm { opacity: 1; }

    /* ---- Preview for new uploads ---- */
    .new-upload-previews {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        margin-top: 10px;
    }
    .new-preview-item {
        position: relative;
        width: 72px;
        height: 72px;
        border-radius: 8px;
        overflow: hidden;
        border: 2px solid #f59e0b;
        flex-shrink: 0;
    }
    .new-preview-item img { width: 100%; height: 100%; object-fit: cover; }
    .new-preview-item .rm-new {
        position: absolute;
        top: 2px; right: 2px;
        width: 20px; height: 20px;
        background: rgba(239,68,68,0.9);
        color: #fff;
        border: none;
        border-radius: 50%;
        font-size: 0.65rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    /* Dark mode file input fix */
    input[type="file"].form-control {
        color: var(--text-main) !important;
        background-color: var(--input-bg) !important;
        border-color: var(--slate-border) !important;
    }
    input[type="file"].form-control::file-selector-button {
        background-color: var(--slate-border);
        color: var(--text-main);
        border: none;
        border-right: 1px solid var(--slate-border);
        padding: 0.375rem 0.75rem;
        margin-right: 0.75rem;
        border-radius: 6px 0 0 6px;
        cursor: pointer;
        transition: background-color 0.15s;
    }
    input[type="file"].form-control::file-selector-button:hover {
        background-color: #f59e0b;
        color: #000;
    }
</style>

<!-- Back button + Title -->
<div class="mb-4">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary d-inline-flex align-items-center gap-1 mb-2" style="font-size:0.8rem;padding:4px 12px;">
        <i class="bi bi-arrow-left"></i> Quay lại danh sách
    </a>
    <h4 class="fw-bold mb-1">Cập nhật sản phẩm</h4>
    <p class="text-muted small mb-0">Chỉnh sửa thông tin chi tiết thiết bị máy ảnh trong hệ thống</p>
</div>

<form asp-action="Edit" method="post" enctype="multipart/form-data" id="editProductForm">
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="ImageUrl" />

    <div class="row g-4 align-items-start">

        <!-- ============ LEFT: Form fields ============ -->
        <div class="col-lg-7">
            <div class="card">
                <div class="card-body p-4">
                    <h6 class="fw-bold mb-4" style="font-size:0.9rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.5px;">
                        <i class="bi bi-info-circle me-1"></i> Thông tin sản phẩm
                    </h6>

                    <div class="mb-3">
                        <label class="form-label">Tên sản phẩm:</label>
                        <input asp-for="Name" class="form-control" placeholder="Nhập tên sản phẩm..." required />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Mô tả sản phẩm:</label>
                        <textarea asp-for="Description" class="form-control" rows="5" placeholder="Mô tả thông tin chi tiết về sản phẩm..."></textarea>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-6 mb-1">
                            <label class="form-label">Giá bán (VND):</label>
                            <div class="input-group">
                                <input asp-for="Price" type="number" step="1000" class="form-control" required />
                                <span class="input-group-text" style="background:var(--table-head-bg);border-color:var(--slate-border);color:var(--text-muted);">đ</span>
                            </div>
                        </div>
                        <div class="col-md-6 mb-1">
                            <label class="form-label">Số lượng tồn kho:</label>
                            <div class="input-group">
                                <input asp-for="StockQuantity" type="number" class="form-control" required />
                                <span class="input-group-text" style="background:var(--table-head-bg);border-color:var(--slate-border);color:var(--text-muted);">cái</span>
                            </div>
                        </div>
                    </div>

                    <div class="mt-3">
                        <label class="form-label">Danh mục sản phẩm:</label>
                        <select asp-for="CategoryProductId" asp-items="@ViewBag.CategoryList" class="form-select" required></select>
                    </div>
                </div>
            </div>

            <!-- Action buttons -->
            <div class="d-flex justify-content-end gap-2 mt-3">
                <a asp-action="Index" class="btn btn-outline-secondary px-4">Hủy bỏ</a>
                <button type="submit" class="btn btn-success px-4 d-inline-flex align-items-center gap-2">
                    <i class="bi bi-check-lg"></i> Cập nhật sản phẩm
                </button>
            </div>
        </div>

        <!-- ============ RIGHT: Image gallery + Upload ============ -->
        <div class="col-lg-5">
            <div class="card">
                <div class="card-body p-4">
                    <h6 class="fw-bold mb-3" style="font-size:0.9rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.5px;">
                        <i class="bi bi-images me-1"></i> Hình ảnh sản phẩm
                        @if (imageList.Any())
                        {
                            <span class="badge bg-primary-subtle text-primary border border-primary ms-1" style="font-size:0.65rem;">@imageList.Count ảnh</span>
                        }
                    </h6>

                    <!-- Main image display -->
                    @if (imageList.Any())
                    {
                        <div class="img-gallery-item mb-3" id="mainImageContainer">
                            <img id="mainPreviewImg" src="@primaryImage" alt="Ảnh chính"
                                 onerror="this.onerror=null;this.src='';this.parentElement.style.background='var(--table-head-bg)';" />
                            <span class="primary-badge"><i class="bi bi-star-fill me-1"></i>Ảnh chính</span>
                        </div>

                        <!-- Thumbnail strip -->
                        @if (imageList.Count > 1)
                        {
                            <div class="img-thumbnails mb-3" id="thumbStrip">
                                @foreach (var img in imageList)
                                {
                                    <div class="img-thumb-item @(img == primaryImage ? "active" : "")"
                                         onclick="setMainImage(this, '@img')">
                                        <img src="@img" alt="thumb"
                                             onerror="this.onerror=null;this.parentElement.style.opacity='0.3';" />
                                        <form asp-action="RemoveImage" method="post" style="display:inline;">
                                            <input type="hidden" name="productId" value="@Model.Id" />
                                            <input type="hidden" name="imageUrl" value="@img" />
                                            <button type="submit" class="rm" title="Xóa ảnh này"
                                                    onclick="return confirm('Xóa ảnh này?')">
                                                <i class="bi bi-x"></i>
                                            </button>
                                        </form>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <!-- Single image: show remove directly -->
                            <form asp-action="RemoveImage" method="post" class="mb-3">
                                <input type="hidden" name="productId" value="@Model.Id" />
                                <input type="hidden" name="imageUrl" value="@primaryImage" />
                                <button type="submit" class="btn btn-sm btn-outline-danger w-100"
                                        onclick="return confirm('Xóa ảnh hiện tại?')">
                                    <i class="bi bi-trash me-1"></i> Xóa ảnh hiện tại
                                </button>
                            </form>
                        }
                    }
                    else
                    {
                        <!-- Empty state -->
                        <div class="img-gallery-item d-flex align-items-center justify-content-center mb-3"
                             style="aspect-ratio:16/9;">
                            <div class="text-center text-muted">
                                <i class="bi bi-image" style="font-size:3rem;opacity:0.25;display:block;"></i>
                                <small>Chưa có hình ảnh</small>
                            </div>
                        </div>
                    }

                    <!-- Upload zone -->
                    <div class="upload-zone" id="uploadZone" onclick="document.getElementById('uploadImages').click()">
                        <i class="bi bi-cloud-upload"></i>
                        <strong style="font-size:0.9rem;">Thêm ảnh mới</strong>
                        <p class="mb-0 mt-1" style="font-size:0.78rem;">Kéo thả hoặc nhấp để chọn nhiều ảnh</p>
                        <p class="mb-0 mt-1" style="font-size:0.72rem;opacity:0.7;">JPG, PNG, WEBP — tối đa 5MB/ảnh</p>
                    </div>
                    <input type="file" id="uploadImages" name="uploadImages" multiple accept="image/*" />

                    <!-- New upload previews -->
                    <div class="new-upload-previews" id="newPreviews"></div>
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <script>
        // Thumbnail switch
        function setMainImage(el, url) {
            document.getElementById('mainPreviewImg').src = url;
            document.querySelectorAll('.img-thumb-item').forEach(t => t.classList.remove('active'));
            el.classList.add('active');
        }

        // Upload zone drag & drop
        var zone = document.getElementById('uploadZone');
        zone.addEventListener('dragover', function(e) {
            e.preventDefault();
            zone.classList.add('drag-over');
        });
        zone.addEventListener('dragleave', function() {
            zone.classList.remove('drag-over');
        });
        zone.addEventListener('drop', function(e) {
            e.preventDefault();
            zone.classList.remove('drag-over');
            var input = document.getElementById('uploadImages');
            // Merge dropped files into input
            var dt = new DataTransfer();
            if (input.files) {
                Array.from(input.files).forEach(f => dt.items.add(f));
            }
            Array.from(e.dataTransfer.files).forEach(f => {
                if (f.type.startsWith('image/')) dt.items.add(f);
            });
            input.files = dt.files;
            previewNewFiles(input.files);
        });

        // File input change → preview
        document.getElementById('uploadImages').addEventListener('change', function() {
            previewNewFiles(this.files);
        });

        function previewNewFiles(files) {
            var container = document.getElementById('newPreviews');
            container.innerHTML = '';
            Array.from(files).forEach(function(file, index) {
                var reader = new FileReader();
                reader.onload = function(e) {
                    var div = document.createElement('div');
                    div.className = 'new-preview-item';
                    div.innerHTML = '<img src="' + e.target.result + '" alt="preview" />'
                        + '<button type="button" class="rm-new" onclick="removeNewPreview(this,' + index + ')" title="Bỏ chọn"><i class="bi bi-x"></i></button>';
                    container.appendChild(div);
                };
                reader.readAsDataURL(file);
            });
        }

        function removeNewPreview(btn, index) {
            var input = document.getElementById('uploadImages');
            var dt = new DataTransfer();
            Array.from(input.files).forEach(function(f, i) {
                if (i !== index) dt.items.add(f);
            });
            input.files = dt.files;
            previewNewFiles(input.files);
        }
    </script>
}
