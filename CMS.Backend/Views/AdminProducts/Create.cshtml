@{
    Layout = "_LayoutAdmin";
}
@model CMS.Data.Entities.Product

<h2 class="text-primary">Thêm sản phẩm mới</h2>
<hr />

<form asp-action="Create" method="post" enctype="multipart/form-data">
    <div class="mb-3">
        <label class="form-label fw-bold">Tên sản phẩm:</label>
        <input asp-for="Name" class="form-control" required />
    </div>
    <div class="mb-3">
        <label class="form-label fw-bold">Mô tả:</label>
        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
    </div>
    <div class="row">
        <div class="col-md-6 mb-3">
            <label class="form-label fw-bold">Giá bán (VND):</label>
            <input asp-for="Price" type="number" step="1000" class="form-control" required />
        </div>
        <div class="col-md-6 mb-3">
            <label class="form-label fw-bold">Số lượng tồn kho:</label>
            <input asp-for="StockQuantity" type="number" class="form-control" required />
        </div>
    </div>
    <div class="mb-3">
        <label class="form-label fw-bold">Danh mục:</label>
        <select asp-for="CategoryProductId" asp-items="@ViewBag.CategoryList" class="form-select" required>
            <option value="">-- Chọn danh mục --</option>
        </select>
    </div>
    <div class="mb-3">
        <label class="form-label fw-bold">Hình ảnh:</label>
        <input type="file" name="uploadImage" class="form-control" accept="image/*" />
    </div>
    <button type="submit" class="btn btn-success"><i class="bi bi-save"></i> Lưu</button>
    <a asp-action="Index" class="btn btn-secondary">Hủy</a>
</form>
