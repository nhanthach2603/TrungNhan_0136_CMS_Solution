<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Quản trị CMS</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        .sidebar {
            min-height: 100vh;
            background-color: #343a40;
        }
        .sidebar .nav-link {
            color: #adb5bd;
            padding: 10px 20px;
        }
        .sidebar .nav-link:hover,
        .sidebar .nav-link.active {
            color: #fff;
            background-color: #495057;
        }
        .sidebar .nav-link i {
            margin-right: 8px;
        }
    </style>
</head>
<body>
    <div class="container-fluid">
        <div class="row">
            <!-- Sidebar -->
            <div class="col-md-3 col-lg-2 sidebar p-0">
                <div class="p-3 text-white text-center border-bottom border-secondary">
                    <h5 class="mb-0"><i class="bi bi-gear-fill"></i> Admin Panel</h5>
                </div>
                @if (User.Identity != null && User.Identity.IsAuthenticated)
                {
                    <div class="p-3 text-white border-bottom border-secondary">
                        <small class="text-muted">Xin chào,</small><br />
                        <strong>@User.FindFirst("FullName")?.Value</strong><br />
                        <span class="badge bg-info">@User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value</span>
                    </div>
                }
                <nav class="nav flex-column">
                    <a class="nav-link" asp-controller="Home" asp-action="Index">
                        <i class="bi bi-speedometer2"></i> Bảng điều khiển
                    </a>
                    <a class="nav-link" asp-controller="Category" asp-action="Index">
                        <i class="bi bi-folder"></i> Category
                    </a>
                    <a class="nav-link" asp-controller="Post" asp-action="Index">
                        <i class="bi bi-file-earmark-text"></i> Post
                    </a>
                    <a class="nav-link" asp-controller="User" asp-action="Index">
                        <i class="bi bi-people"></i> User
                    </a>
                    <a class="nav-link" asp-controller="AdminCategoriesProducts" asp-action="Index">
                        <i class="bi bi-grid"></i> ProductCategory
                    </a>
                    <a class="nav-link" asp-controller="AdminProducts" asp-action="Index">
                        <i class="bi bi-box"></i> Product
                    </a>
                    <a class="nav-link" asp-controller="AdminBannerImages" asp-action="Index">
                        <i class="bi bi-image"></i> Banner
                    </a>
                    <a class="nav-link" href="#">
                        <i class="bi bi-person-lines-fill"></i> Customer
                    </a>
                    <a class="nav-link" href="#">
                        <i class="bi bi-cart"></i> Order
                    </a>
                    <a class="nav-link" href="#">
                        <i class="bi bi-receipt"></i> OrderDetail
                    </a>
                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <a class="nav-link text-danger mt-3 border-top border-secondary pt-3" asp-controller="Account" asp-action="Logout">
                            <i class="bi bi-box-arrow-left"></i> Đăng xuất
                        </a>
                    }
                </nav>
            </div>

            <!-- Main Content -->
            <div class="col-md-9 col-lg-10">
                <div class="p-4">
                    @RenderBody()
                </div>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
