<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Camera24h Quản trị</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
    
    <!-- Google Fonts - Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
</head>
<body>
    <script>
        (function () {
            var t = localStorage.getItem('admin-theme') || 'light';
            document.documentElement.setAttribute('data-theme', t);
            document.body.setAttribute('data-theme', t);
        })();
    </script>

    <!-- Sidebar overlay (mobile) -->
    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    <div class="admin-shell">
        <!-- ======================== SIDEBAR ======================== -->
        <aside class="sidebar" id="adminSidebar">
            <a class="sidebar-brand" asp-controller="Home" asp-action="Index">
                <i class="bi bi-camera2"></i>
                Camera24h<span>.Shop</span>
            </a>

            @if (User.Identity != null && User.Identity.IsAuthenticated)
            {
                <div class="sidebar-user">
                    <small>Quản trị viên</small>
                    <strong>@User.FindFirst("FullName")?.Value</strong>
                    <span class="badge">@User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value</span>
                </div>
            }

            <nav class="nav flex-column">
                <a class="nav-link" asp-controller="Home" asp-action="Index" id="nav-dashboard">
                    <i class="bi bi-grid-1x2-fill"></i> Tổng quan
                </a>

                <div class="sidebar-section-label">Bán hàng</div>

                <a class="nav-link" asp-controller="AdminProducts" asp-action="Index" id="nav-products">
                    <i class="bi bi-box-seam"></i> Sản phẩm
                </a>
                <a class="nav-link" asp-controller="AdminCategoriesProducts" asp-action="Index" id="nav-category-products">
                    <i class="bi bi-tags"></i> Danh mục SP
                </a>
                <a class="nav-link" asp-controller="AdminOrders" asp-action="Index" id="nav-orders">
                    <i class="bi bi-receipt"></i> Đơn đặt hàng
                </a>
                <a class="nav-link" asp-controller="AdminCustomers" asp-action="Index" id="nav-customers">
                    <i class="bi bi-people"></i> Khách hàng
                </a>

                <div class="sidebar-section-label">Nội dung</div>

                <a class="nav-link" asp-controller="Post" asp-action="Index" id="nav-posts">
                    <i class="bi bi-file-earmark-text"></i> Bài viết tin tức
                </a>
                <a class="nav-link" asp-controller="Category" asp-action="Index" id="nav-post-categories">
                    <i class="bi bi-folder2-open"></i> Danh mục bài
                </a>
                <a class="nav-link" asp-controller="AdminBannerImages" asp-action="Index" id="nav-banners">
                    <i class="bi bi-images"></i> Banner quảng cáo
                </a>

                <div class="sidebar-section-label">Hệ thống</div>

                <a class="nav-link" asp-controller="User" asp-action="Index" id="nav-users">
                    <i class="bi bi-shield-lock"></i> Tài khoản Admin
                </a>
            </nav>
        </aside>

        <!-- ======================== MAIN ======================== -->
        <div class="admin-main">
            <!-- Top Header -->
            <header class="main-header-admin">
                <div class="header-left">
                    <button class="btn-hamburger" id="hamburgerBtn" aria-label="Toggle menu">
                        <i class="bi bi-list"></i>
                    </button>
                    <nav class="admin-breadcrumb" aria-label="breadcrumb">
                        <span>Trang quản trị</span>
                        <i class="bi bi-chevron-right" style="font-size: 0.6rem; opacity: 0.5;"></i>
                        <span class="bc-current">@ViewData["Title"]</span>
                    </nav>
                </div>

                <div class="admin-header-actions">
                    <div class="admin-search-wrap">
                        <i class="bi bi-search"></i>
                        <input type="text" class="admin-search-input" placeholder="Tìm kiếm nhanh..." />
                    </div>

                    <button id="theme-toggle" title="Thay đổi giao diện" aria-label="Toggle theme">
                        <i class="bi bi-sun-fill"></i>
                    </button>

                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        var name = User.FindFirst("FullName")?.Value ?? "A";
                        var firstLetter = name.Substring(0, 1).ToUpper();
                        <div class="dropdown">
                            <button class="admin-avatar-btn dropdown-toggle" id="avatarDropdown"
                                    data-bs-toggle="dropdown" aria-expanded="false"
                                    title="@name">
                                @firstLetter
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end admin-dropdown-menu" aria-labelledby="avatarDropdown">
                                <li>
                                    <div class="dropdown-header">
                                        <div class="user-name">@name</div>
                                        <div class="user-role">@User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value</div>
                                    </div>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-controller="User" asp-action="Index">
                                        <i class="bi bi-person"></i> Hồ sơ tài khoản
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <a class="dropdown-item text-danger" asp-controller="Account" asp-action="Logout">
                                        <i class="bi bi-box-arrow-right"></i> Đăng xuất
                                    </a>
                                </li>
                            </ul>
                        </div>
                    }
                </div>
            </header>

            <!-- Page Content -->
            <main class="admin-content-body">
                @RenderBody()
            </main>
        </div><!-- /admin-main -->
    </div><!-- /admin-shell -->

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        $(document).ready(function () {

            /* ---- Apply theme to body on load ---- */
            var savedTheme = localStorage.getItem('admin-theme') || 'light';
            $('html, body').attr('data-theme', savedTheme);
            updateThemeIcon(savedTheme);

            /* ---- Active nav highlight ---- */
            var url = window.location.pathname;
            $('.sidebar .nav-link').removeClass('active');
            if (url === '/' || url.toLowerCase().includes('/home')) {
                $('#nav-dashboard').addClass('active');
            } else if (url.includes('AdminProducts'))            { $('#nav-products').addClass('active'); }
            else if (url.includes('AdminCategoriesProducts'))    { $('#nav-category-products').addClass('active'); }
            else if (url.includes('AdminOrders'))                { $('#nav-orders').addClass('active'); }
            else if (url.includes('AdminCustomers'))             { $('#nav-customers').addClass('active'); }
            else if (url.includes('Post') && !url.includes('Category')) { $('#nav-posts').addClass('active'); }
            else if (url.includes('Category') && !url.includes('Admin')) { $('#nav-post-categories').addClass('active'); }
            else if (url.includes('AdminBannerImages'))          { $('#nav-banners').addClass('active'); }
            else if (url.includes('User'))                       { $('#nav-users').addClass('active'); }

            /* ---- Theme toggle ---- */
            function updateThemeIcon(theme) {
                var icon = $('#theme-toggle i');
                if (theme === 'dark') {
                    icon.removeClass('bi-sun-fill').addClass('bi-moon-stars-fill');
                } else {
                    icon.removeClass('bi-moon-stars-fill').addClass('bi-sun-fill');
                }
            }

            $('#theme-toggle').on('click', function () {
                var current = $('html').attr('data-theme') || 'light';
                var next = current === 'dark' ? 'light' : 'dark';
                $('html, body').attr('data-theme', next);
                localStorage.setItem('admin-theme', next);
                updateThemeIcon(next);
            });

            /* ---- Mobile sidebar toggle ---- */
            $('#hamburgerBtn').on('click', function () {
                $('#adminSidebar').toggleClass('open');
                $('#sidebarOverlay').toggleClass('show');
            });
            $('#sidebarOverlay').on('click', function () {
                $('#adminSidebar').removeClass('open');
                $('#sidebarOverlay').removeClass('show');
            });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
