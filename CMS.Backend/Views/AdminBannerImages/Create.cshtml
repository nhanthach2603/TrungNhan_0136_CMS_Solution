@model CMS.Data.Entities.BannerImage
@{ ViewData["Title"] = "Thêm Banner"; Layout = "~/Views/Shared/_LayoutAdmin.cshtml"; }

<h4><i class="bi bi-plus-circle"></i> Thêm Banner mới</h4>
<hr />

<div class="row">
    <div class="col-md-8">
        <form asp-action="Create" enctype="multipart/form-data">
            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label class="form-label fw-bold">Tên banner</label>
                <input asp-for="Name" class="form-control" placeholder="VD: Summer Sale 2026" required />
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">Ảnh banner</label>
                <input type="file" name="uploadImage" class="form-control" accept="image/*" />
                <small class="text-muted">Kích thước khuyến nghị: 1920x600px</small>
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">Link (tùy chọn)</label>
                <input asp-for="LinkUrl" class="form-control" placeholder="/product/1 hoặc https://..." />
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Thứ tự hiển thị</label>
                    <input asp-for="SortOrder" type="number" class="form-control" value="0" />
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Trạng thái</label>
                    <select asp-for="IsActive" class="form-control">
                        <option value="true">Hiển thị</option>
                        <option value="false">Ẩn</option>
                    </select>
                </div>
            </div>

            <button type="submit" class="btn btn-primary"><i class="bi bi-check-circle"></i> Lưu</button>
            <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
        </form>
    </div>
</div>
