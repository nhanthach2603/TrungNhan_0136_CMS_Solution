@model CMS.Data.Entities.BannerImage
@{ ViewData["Title"] = "Sửa Banner"; Layout = "~/Views/Shared/_LayoutAdmin.cshtml"; }

<h4><i class="bi bi-pencil-square"></i> Sửa Banner</h4>
<hr />

<div class="row">
    <div class="col-md-8">
        <form asp-action="Edit" enctype="multipart/form-data">
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="ImageUrl" />
            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label class="form-label fw-bold">Tên banner</label>
                <input asp-for="Name" class="form-control" required />
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">Ảnh hiện tại</label>
                <div>
                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <img src="@Model.ImageUrl" alt="@Model.Name" style="max-height:120px;border-radius:6px;object-fit:cover;" />
                    }
                    else
                    {
                        <span class="text-muted">Chưa có ảnh</span>
                    }
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">Thay ảnh mới (bỏ trống nếu giữ nguyên)</label>
                <input type="file" name="uploadImage" class="form-control" accept="image/*" />
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">Link (tùy chọn)</label>
                <input asp-for="LinkUrl" class="form-control" />
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Thứ tự hiển thị</label>
                    <input asp-for="SortOrder" type="number" class="form-control" />
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Trạng thái</label>
                    <select asp-for="IsActive" class="form-control">
                        <option value="true">Hiển thị</option>
                        <option value="false">Ẩn</option>
                    </select>
                </div>
            </div>

            <button type="submit" class="btn btn-primary"><i class="bi bi-check-circle"></i> Cập nhật</button>
            <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
        </form>
    </div>
</div>
