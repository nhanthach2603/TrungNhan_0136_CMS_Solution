@{
    Layout = "_LayoutAdmin";
}
@model IEnumerable<CMS.Data.Entities.CategoryProduct>

<h2 class="text-primary"><i class="bi bi-grid"></i> QUẢN LÝ DANH MỤC SẢN PHẨM</h2>
<hr />
<a asp-action="Create" class="btn btn-success mb-3">
    <i class="bi bi-plus-circle"></i> Thêm danh mục mới
</a>

<table class="table table-bordered table-hover">
    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>Tên danh mục</th>
            <th>Mô tả</th>
            <th style="width:160px">Thao tác</th>
        </tr>
    </thead>
    <tbody>
        @if (!Model.Any())
        {
            <tr><td colspan="4" class="text-center text-muted">Chưa có danh mục nào.</td></tr>
        }
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td><strong>@item.Name</strong></td>
                <td>@item.Description</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning">Sửa</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger"
                       onclick="return confirm('Xóa danh mục này?')">Xóa</a>
                </td>
            </tr>
        }
    </tbody>
</table>
